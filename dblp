PUBLICATION_TAGS = {
    "article",
    "inproceedings",
    "proceedings",
    "book",
    "incollection",
    "phdthesis",
    "mastersthesis",
    "www",
}

ENTRY_TYPE_MAP = {
    "article": "article",
    "inproceedings": "inproceedings",
    "proceedings": "proceedings",
    "book": "book",
    "incollection": "incollection",
    "phdthesis": "phdthesis",
    "mastersthesis": "mastersthesis",
    "www": "misc",
}

MULTI_VALUE_FIELDS = {
    "author",
    "editor",
    "isbn",
    "ee",
    "url",
}

BIBTEX_FIELD_ORDER = [
    "author",
    "editor",
    "title",
    "booktitle",
    "journal",
    "series",
    "volume",
    "number",
    "pages",
    "publisher",
    "school",
    "year",
    "isbn",
    "url",
    "doi",
    "timestamp",
    "biburl",
    "bibsource",
]

XML_PREDEFINED_ENTITIES = {"amp", "lt", "gt", "quot", "apos"}
NAMED_ENTITY_RE = re.compile(r"&([A-Za-z][A-Za-z0-9]+);")
ACRONYM_RE = re.compile(r"\b[A-Z][A-Z0-9]*(?:/[A-Z0-9]+)*(?:'[0-9]{2})?\b")
RECORD_START_RE = re.compile(
    r"<(article|inproceedings|proceedings|book|incollection|phdthesis|mastersthesis|www)\b[^>]*\bkey=\"([^\"]+)\""
)
TITLE_RE = re.compile(r"<title(?:\s[^>]*)?>(.*?)</title>", re.DOTALL)
XML_TAG_RE = re.compile(r"<[^>]+>")
DEFAULT_XML_URLS = [
    "https://dblp.org/xml/dblp.xml.gz",
    "https://dblp.uni-trier.de/xml/dblp.xml.gz",
]
INDEX_SCHEMA_VERSION = 5
REQUEST_TIMEOUT = 20
XML_FILENAME = "dblp.xml.gz"


def normalize_title(title: str) -> str:
    normalized = re.sub(r"\s+", " ", title).strip().casefold()
    return normalized.rstrip(".").strip()


def escape_bibtex(value: str) -> str:
    return value.replace("\\", "\\\\")


def element_text(elem: ET.Element) -> str:
    return re.sub(r"\s+", " ", "".join(elem.itertext())).strip()


def sanitize_xml_entities(text: str) -> str:
    def replace(match: re.Match[str]) -> str:
        entity = match.group(1)
        if entity in XML_PREDEFINED_ENTITIES:
            return match.group(0)
        codepoint = html.entities.name2codepoint.get(entity)
        if codepoint is None:
            return match.group(0)
        return f"&#{codepoint};"

    return NAMED_ENTITY_RE.sub(replace, text)


def decode_xml_text(text: str) -> str:
    return re.sub(r"\s+", " ", html.unescape(sanitize_xml_entities(text))).strip()


def parse_record_xml(record_xml: str) -> ET.Element:
    return ET.fromstring(sanitize_xml_entities(record_xml))


def title_from_record_xml(record_xml: str) -> str:
    title_match = TITLE_RE.search(record_xml)
    if title_match is None:
        return ""
    return decode_xml_text(XML_TAG_RE.sub("", title_match.group(1)))


def iter_index_entries(xml_gz_path: str) -> Iterator[tuple[str, str, str]]:
    current_tag: Optional[str] = None
    current_key: Optional[str] = None
    lines: List[str] = []

    with gzip.open(xml_gz_path, "rt", encoding="ascii", errors="ignore") as source:
        for raw_line in source:
            remaining = raw_line
            while remaining:
                if current_tag is None:
                    start_match = RECORD_START_RE.search(remaining)
                    if start_match is None:
                        break

                    current_tag = start_match.group(1)
                    current_key = start_match.group(2)
                    remaining = remaining[start_match.start() :]
                    lines = []

                close_tag = f"</{current_tag}>"
                close_index = remaining.find(close_tag)
                if close_index == -1:
                    lines.append(remaining)
                    break

                close_end = close_index + len(close_tag)
                lines.append(remaining[:close_end])
                record_xml = "".join(lines)
                title = title_from_record_xml(record_xml)
                if title and current_key is not None:
                    yield normalize_title(title), current_key, record_xml

                remaining = remaining[close_end:]
                current_tag = None
                current_key = None
                lines = []


def extract_record(elem: ET.Element) -> Dict[str, object]:
    record: Dict[str, object] = {
        "entry_type": ENTRY_TYPE_MAP[elem.tag],
        "citekey": elem.attrib.get("key", "dblp/unknown"),
    }
    if "mdate" in elem.attrib:
        record["mdate"] = elem.attrib["mdate"]

    for child in elem:
        tag = child.tag
        if tag not in MULTI_VALUE_FIELDS and tag not in {
            "title",
            "booktitle",
            "journal",
            "series",
            "volume",
            "number",
            "pages",
            "publisher",
            "school",
            "year",
            "crossref",
            "note",
        }:
            continue

        text = element_text(child)
        if not text:
            continue

        if tag in MULTI_VALUE_FIELDS:
            record.setdefault(tag, []).append(text)
        else:
            record[tag] = text

    ee_values = record.get("ee", [])
    if isinstance(ee_values, list):
        doi_values = []
        url_values = []
        for value in ee_values:
            if value.startswith("https://doi.org/") or value.startswith("http://doi.org/"):
                doi_values.append(re.sub(r"^https?://doi\.org/", "", value))
            else:
                url_values.append(value)
        if doi_values:
            record["doi"] = doi_values[0]
        if url_values and "url" not in record:
            record["url"] = url_values[0]

    url_values = record.get("url", [])
    if isinstance(url_values, list):
        if url_values:
            record["url"] = url_values[0]
        else:
            record.pop("url", None)

    return record


def strip_title_period(value: str) -> str:
    return value[:-1] if value.endswith(".") else value


def format_pages(value: str) -> str:
    return re.sub(r"(?<=\d)-(?=\d)", "--", value)


def protect_acronyms(value: str) -> str:
    def replace(match: re.Match[str]) -> str:
        return f"{{{match.group(0)}}}"

    return ACRONYM_RE.sub(replace, value)


def format_timestamp(mdate: object) -> Optional[str]:
    if not isinstance(mdate, str):
        return None
    try:
        parsed = datetime.strptime(mdate, "%Y-%m-%d")
    except ValueError:
        return None
    return parsed.strftime("%a, %d %b %Y 00:00:00 +0000")


def enrich_record_with_crossref(
    record: Dict[str, object],
    crossref_record: Optional[Dict[str, object]],
) -> Dict[str, object]:
    if crossref_record is None:
        return record

    enriched = dict(record)
    for field in ("editor", "publisher", "series", "volume", "number"):
        if field not in enriched and field in crossref_record:
            enriched[field] = crossref_record[field]

    if record.get("entry_type") == "inproceedings" and "title" in crossref_record:
        enriched["booktitle"] = crossref_record["title"]

    return enriched


def render_bibtex_value(field: str, value: object) -> str | List[str]:
    if isinstance(value, list):
        return [escape_bibtex(str(item)) for item in value]

    rendered = str(value)
    if field == "title":
        rendered = strip_title_period(rendered)
    elif field == "pages":
        rendered = format_pages(rendered)

    if field in {"booktitle", "publisher", "series"}:
        rendered = protect_acronyms(rendered)

    return escape_bibtex(rendered)


def format_bibtex_field(field: str, value: object) -> List[str]:
    prefix = f"  {field:<13}= "
    continuation = " " * (len(prefix) + 1)

    if isinstance(value, list) and field in {"author", "editor"}:
        if not value:
            return []

        rendered_values = [str(item) for item in render_bibtex_value(field, value)]
        if len(rendered_values) == 1:
            return [f"{prefix}{{{rendered_values[0]}}},"]

        lines = [f"{prefix}{{{rendered_values[0]} and"]
        for item in rendered_values[1:-1]:
            lines.append(f"{continuation}{item} and")
        lines.append(f"{continuation}{rendered_values[-1]}}},")
        return lines

    rendered = str(render_bibtex_value(field, value))
    wrapped = textwrap.wrap(
        rendered,
        width=80 - len(continuation),
        break_long_words=False,
        break_on_hyphens=False,
    ) or [""]

    lines = [f"{prefix}{{{wrapped[0]}"]
    lines.extend(f"{continuation}{line}" for line in wrapped[1:])
    lines[-1] = f"{lines[-1]}}},"
    return lines


def format_bibtex(record: Dict[str, object]) -> str:
    formatted_record = dict(record)
    citekey = str(formatted_record["citekey"])
    doi = formatted_record.get("doi")
    if doi:
        formatted_record["url"] = f"https://doi.org/{doi}"

    timestamp = format_timestamp(formatted_record.get("mdate"))
    if timestamp:
        formatted_record["timestamp"] = timestamp
    formatted_record["biburl"] = f"https://dblp.org/rec/{citekey}.bib"
    formatted_record["bibsource"] = "dblp computer science bibliography, https://dblp.org"

    lines = [f"@{formatted_record['entry_type']}{{DBLP:{citekey},"]

    for field in BIBTEX_FIELD_ORDER:
        value = formatted_record.get(field)
        if not value:
            continue

        lines.extend(format_bibtex_field(field, value))

    if lines[-1].endswith(","):
        lines[-1] = lines[-1][:-1]
    lines.append("}")
    return "\n".join(lines)


def default_index_path(xml_gz_path: str) -> str:
    return f"{xml_gz_path}.idx.sqlite3"


def connect_index(index_path: str, *, readonly: bool = False) -> sqlite3.Connection:
    if readonly:
        uri = f"file:{urllib.parse.quote(os.path.abspath(index_path))}?mode=ro"
        connection = sqlite3.connect(uri, uri=True)
        connection.execute("PRAGMA query_only=ON")
        return connection

    connection = sqlite3.connect(index_path)
    connection.execute("PRAGMA journal_mode=WAL")
    connection.execute("PRAGMA synchronous=NORMAL")
    return connection


def initialize_index(connection: sqlite3.Connection) -> None:
    connection.executescript(
        """
        CREATE TABLE IF NOT EXISTS metadata (
            key TEXT PRIMARY KEY,
            value TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS records (
            normalized_title TEXT NOT NULL,
            citekey TEXT NOT NULL,
            record_xml TEXT NOT NULL
        );

        CREATE INDEX IF NOT EXISTS idx_records_normalized_title
        ON records(normalized_title);

        CREATE INDEX IF NOT EXISTS idx_records_citekey
        ON records(citekey);

        CREATE VIRTUAL TABLE IF NOT EXISTS title_fts
        USING fts5(
            normalized_title,
            content='records',
            content_rowid='rowid',
            tokenize='trigram',
            detail='none',
            columnsize=0
        );

        """
    )


def read_index_metadata(connection: sqlite3.Connection) -> Dict[str, str]:
    rows = connection.execute("SELECT key, value FROM metadata").fetchall()
    return {key: value for key, value in rows}


def write_index_metadata(
    connection: sqlite3.Connection,
    *,
    xml_gz_path: str,
    stat_result: os.stat_result,
) -> None:
    metadata = {
        "schema_version": str(INDEX_SCHEMA_VERSION),
        "source_path": os.path.abspath(xml_gz_path),
        "source_size": str(stat_result.st_size),
        "source_mtime_ns": str(stat_result.st_mtime_ns),
    }
    connection.executemany(
        "REPLACE INTO metadata(key, value) VALUES(?, ?)",
        metadata.items(),
    )


def index_is_fresh(
    metadata: Dict[str, str],
    *,
    xml_gz_path: str,
    stat_result: os.stat_result,
) -> bool:
    expected = {
        "schema_version": str(INDEX_SCHEMA_VERSION),
        "source_path": os.path.abspath(xml_gz_path),
        "source_size": str(stat_result.st_size),
        "source_mtime_ns": str(stat_result.st_mtime_ns),
    }
    return all(metadata.get(key) == value for key, value in expected.items())


def rebuild_index(connection: sqlite3.Connection, xml_gz_path: str) -> None:
    rebuild_index_with_metadata_path(connection, xml_gz_path, xml_gz_path)


def rebuild_index_with_metadata_path(
    connection: sqlite3.Connection,
    xml_gz_path: str,
    metadata_xml_gz_path: str,
) -> None:
    stat_result = os.stat(xml_gz_path)
    connection.execute("PRAGMA journal_mode=OFF")
    connection.execute("PRAGMA synchronous=OFF")
    connection.execute("PRAGMA temp_store=MEMORY")
    connection.execute("DROP TABLE IF EXISTS title_fts")
    connection.execute("DROP TABLE IF EXISTS records")
    connection.execute("DROP TABLE IF EXISTS bib_cache")
    connection.execute(
        """
        CREATE TABLE records (
            normalized_title TEXT NOT NULL,
            citekey TEXT NOT NULL,
            record_xml TEXT NOT NULL
        )
        """
    )

    rows: List[tuple[str, str, str]] = []
    batch_size = 20000

    def flush_rows() -> None:
        if rows:
            connection.executemany(
                "INSERT INTO records(normalized_title, citekey, record_xml) VALUES(?, ?, ?)",
                rows,
            )
            rows.clear()

    for normalized_title, citekey, record_xml in iter_index_entries(xml_gz_path):
        rows.append((normalized_title, citekey, record_xml))
        if len(rows) >= batch_size:
            flush_rows()

    flush_rows()
    connection.execute(
        """
        CREATE INDEX idx_records_normalized_title
        ON records(normalized_title)
        """
    )
    connection.execute(
        """
        CREATE INDEX idx_records_citekey
        ON records(citekey)
        """
    )
    connection.execute(
        """
        CREATE VIRTUAL TABLE title_fts
        USING fts5(
            normalized_title,
            content='records',
            content_rowid='rowid',
            tokenize='trigram',
            detail='none',
            columnsize=0
        )
        """
    )
    connection.execute("INSERT INTO title_fts(title_fts) VALUES('rebuild')")

    write_index_metadata(
        connection,
        xml_gz_path=metadata_xml_gz_path,
        stat_result=stat_result,
    )
    connection.commit()
    connection.execute("PRAGMA synchronous=NORMAL")


def open_fresh_index(xml_gz_path: str, index_path: str) -> sqlite3.Connection:
    if not os.path.exists(index_path):
        raise RuntimeError(f"Index not found: {index_path}. Run `dblp update` first.")

    connection = connect_index(index_path, readonly=True)
    try:
        stat_result = os.stat(xml_gz_path)
        metadata = read_index_metadata(connection)
    except Exception:
        connection.close()
        raise RuntimeError(f"Index is unreadable or incomplete: {index_path}")

    if not index_is_fresh(metadata, xml_gz_path=xml_gz_path, stat_result=stat_result):
        connection.close()
        raise RuntimeError(f"Index is stale: {index_path}. Run `dblp update` first.")

    return connection


def remove_sqlite_sidecars(index_path: str) -> None:
    for path in (f"{index_path}-wal", f"{index_path}-shm", f"{index_path}-journal"):
        try:
            os.unlink(path)
        except FileNotFoundError:
            pass


def rebuild_index_for_paths(xml_gz_path: str, index_path: str) -> None:
    index_dir = os.path.dirname(os.path.abspath(index_path)) or "."
    os.makedirs(index_dir, exist_ok=True)
    fd, tmp_index_path = tempfile.mkstemp(
        prefix=f".{os.path.basename(index_path)}.",
        suffix=".tmp",
        dir=index_dir,
    )
    os.close(fd)

    connection = connect_index(tmp_index_path)
    try:
        initialize_index(connection)
        rebuild_index(connection, xml_gz_path)
        connection.close()
        remove_sqlite_sidecars(index_path)
        os.replace(tmp_index_path, index_path)
    finally:
        try:
            connection.close()
        except Exception:
            pass
        for path in (
            tmp_index_path,
            f"{tmp_index_path}-wal",
            f"{tmp_index_path}-shm",
            f"{tmp_index_path}-journal",
        ):
            try:
                os.unlink(path)
            except FileNotFoundError:
                pass


def cached_records(
    connection: sqlite3.Connection,
    citekeys: Iterable[str],
) -> Dict[str, Dict[str, object]]:
    unique_citekeys = list(dict.fromkeys(citekeys))
    if not unique_citekeys:
        return {}

    placeholders = ",".join("?" for _ in unique_citekeys)
    rows = connection.execute(
        f"SELECT citekey, record_xml FROM records WHERE citekey IN ({placeholders})",
        unique_citekeys,
    ).fetchall()
    return {citekey: extract_record(parse_record_xml(record_xml)) for citekey, record_xml in rows}


def indexed_bibtex(connection: sqlite3.Connection, citekeys: List[str]) -> Dict[str, str]:
    bibtex_by_key: Dict[str, str] = {}
    records = cached_records(connection, citekeys)
    crossref_keys = [
        str(record["crossref"])
        for record in records.values()
        if isinstance(record.get("crossref"), str)
    ]
    crossref_records = cached_records(connection, crossref_keys)

    for citekey in citekeys:
        record = records.get(citekey)
        if record is None:
            continue

        crossref_key = record.get("crossref")
        crossref_record = (
            crossref_records.get(crossref_key)
            if isinstance(crossref_key, str)
            else None
        )
        enriched_record = enrich_record_with_crossref(record, crossref_record)
        bibtex_by_key[citekey] = format_bibtex(enriched_record)

    return bibtex_by_key


def alfred_items(message: str, subtitle: str = "", *, valid: bool = False) -> Dict[str, Any]:
    return {
        "items": [
            {
                "title": message,
                "subtitle": subtitle,
                "valid": valid,
            }
        ]
    }


def request_url(
    server: str,
    path: str,
    token: str,
    query: Optional[Dict[str, str]] = None,
) -> urllib.request.Request:
    url = f"{server.rstrip('/')}{path}"
    if query:
        url = f"{url}?{urllib.parse.urlencode(query)}"
    request = urllib.request.Request(url)
    if token:
        request.add_header("Authorization", f"Bearer {token}")
    return request


def query_server(server: str, token: str, query: str, limit: int) -> Dict[str, Any]:
    request = request_url(server, "/query", token, {"q": query, "limit": str(limit)})
    with urllib.request.urlopen(request, timeout=REQUEST_TIMEOUT) as response:
        return json.loads(response.read().decode("utf-8"))


def record_items(
    records: Dict[str, Dict[str, object]],
    bibtex_by_key: Dict[str, str],
    citekeys: Iterable[str],
) -> List[Dict[str, Any]]:
    items = []
    for citekey in citekeys:
        record = records.get(citekey)
        bibtex = bibtex_by_key.get(citekey)
        if record is None or bibtex is None:
            continue

        authors = record.get("author", [])
        if isinstance(authors, str):
            author_text = authors
        elif isinstance(authors, list):
            author_text = ", ".join(str(author) for author in authors[:8])
            if len(authors) > 8:
                author_text += ", ..."
        else:
            author_text = ""

        year = record.get("year")
        subtitle_parts = [part for part in (author_text, str(year) if year else "") if part]
        items.append(
            {
                "title": str(record.get("title", citekey)),
                "subtitle": " | ".join(subtitle_parts),
                "citekey": citekey,
                "bibtex": bibtex,
                "arg": bibtex,
            }
        )
    return items


def query_local_index(index_path: str, query: str, limit: int) -> Dict[str, Any]:
    connection = connect_index(index_path, readonly=True)
    try:
        metadata = read_index_metadata(connection)
        if metadata.get("schema_version") != str(INDEX_SCHEMA_VERSION):
            raise RuntimeError("local index schema is stale")
        citekeys = find_match_keys_in_index(connection, query)[:limit]
        records = cached_records(connection, citekeys)
        bibtex_by_key = indexed_bibtex(connection, citekeys)
    finally:
        connection.close()
    return {"items": record_items(records, bibtex_by_key, citekeys)}


def configured_index_path(file_path: Optional[str] = None, index_path: Optional[str] = None) -> str:
    if index_path:
        return index_path

    if file_path:
        return default_index_path(file_path)

    db_path = os.environ.get("DB_PATH", settings.DB_PATH)
    return default_index_path(os.path.join(db_path, XML_FILENAME))


def query_with_fallback(
    query: str,
    limit: int,
    *,
    file_path: Optional[str] = None,
    index_path: Optional[str] = None,
) -> Dict[str, Any]:
    resolved_index_path = configured_index_path(file_path, index_path)
    if resolved_index_path and os.path.exists(resolved_index_path):
        try:
            return query_local_index(resolved_index_path, query, limit)
        except Exception as exc:
            print(f"Local DBLP index failed, falling back to server: {exc}", file=sys.stderr)

    server = os.environ.get("DBLP_SERVER", settings.DBLP_SERVER).strip()
    token = os.environ.get("DBLP_TOKEN", settings.DBLP_TOKEN)
    if not server:
        return alfred_items("DBLP server is not configured", "Set DBLP_SERVER in settings.py")

    try:
        payload = query_server(server, token, query, limit)
    except urllib.error.HTTPError as exc:
        detail = exc.reason
        try:
            error_payload = json.loads(exc.read().decode("utf-8"))
            if isinstance(error_payload, dict) and error_payload.get("error"):
                detail = str(error_payload["error"])
        except Exception:
            pass
        return alfred_items(f"DBLP server error: HTTP {exc.code}", detail)
    except Exception as exc:
        return alfred_items(f"DBLP server error: {exc}", "Check settings.py")

    if "error" in payload and "items" not in payload:
        return alfred_items(f"DBLP server error: {payload['error']}", "Try again later")
    return {"items": payload.get("items", [])}


def pull_index_from_server() -> int:
    server = os.environ.get("DBLP_SERVER", settings.DBLP_SERVER).strip()
    token = os.environ.get("DBLP_TOKEN", settings.DBLP_TOKEN)
    index_path = configured_index_path()
    if not server:
        print("DBLP_SERVER is not configured in settings.py", file=sys.stderr)
        return 2
    if not index_path:
        print("DB_PATH is not configured in settings.py", file=sys.stderr)
        return 2

    index_dir = os.path.dirname(os.path.abspath(index_path)) or "."
    os.makedirs(index_dir, exist_ok=True)
    fd, tmp_index = tempfile.mkstemp(
        prefix=f".{os.path.basename(index_path)}.",
        suffix=".tmp",
        dir=index_dir,
    )
    os.close(fd)

    try:
        request = request_url(server, "/index.gz", token)
        with urllib.request.urlopen(request, timeout=None) as response, gzip.GzipFile(fileobj=response, mode="rb") as compressed, open(tmp_index, "wb") as output:
            while True:
                chunk = compressed.read(1024 * 1024)
                if not chunk:
                    break
                output.write(chunk)

        connection = sqlite3.connect(tmp_index)
        try:
            quick_check = connection.execute("PRAGMA quick_check").fetchone()[0]
            if quick_check != "ok":
                raise RuntimeError(f"downloaded index failed quick_check: {quick_check}")
            metadata = read_index_metadata(connection)
            if metadata.get("schema_version") != str(INDEX_SCHEMA_VERSION):
                raise RuntimeError("downloaded index schema is stale")
        finally:
            connection.close()

        os.replace(tmp_index, index_path)
        print(f"Pulled DBLP index to {index_path} ({os.path.getsize(index_path)} bytes)")
        return 0
    except Exception as exc:
        print(f"Failed to pull DBLP index: {exc}", file=sys.stderr)
        return 1
    finally:
        try:
            os.unlink(tmp_index)
        except FileNotFoundError:
            pass


def find_match_keys_in_index(connection: sqlite3.Connection, title_query: str) -> List[str]:
    target = normalize_title(title_query)
    if not target:
        return []

    exact_rows = connection.execute(
        "SELECT citekey FROM records WHERE normalized_title = ? LIMIT 10",
        (target,),
    ).fetchall()
    if exact_rows:
        return [row[0] for row in exact_rows]

    fallback_rows = connection.execute(
        """
        SELECT records.citekey
        FROM title_fts
        JOIN records ON records.rowid = title_fts.rowid
        WHERE title_fts.normalized_title LIKE ?
        LIMIT 10
        """,
        (f"%{target}%",),
    ).fetchall()
    return [row[0] for row in fallback_rows]


def find_match_keys(xml_gz_path: str, title_query: str, index_path: Optional[str] = None) -> List[str]:
    resolved_index_path = index_path or default_index_path(xml_gz_path)
    connection = open_fresh_index(xml_gz_path, resolved_index_path)
    try:
        return find_match_keys_in_index(connection, title_query)
    finally:
        connection.close()


def download_file(url: str, destination: str) -> None:
    destination_dir = os.path.dirname(os.path.abspath(destination)) or "."
    os.makedirs(destination_dir, exist_ok=True)

    fd, tmp_path = tempfile.mkstemp(
        prefix=".dblp-download-",
        suffix=".tmp",
        dir=destination_dir,
    )
    os.close(fd)

    try:
        request = urllib.request.Request(url, headers={"User-Agent": "dblp-cli/1.0"})
        with urllib.request.urlopen(request) as response, open(tmp_path, "wb") as out:
            while True:
                chunk = response.read(1024 * 1024)
                if not chunk:
                    break
                out.write(chunk)
        os.replace(tmp_path, destination)
    except Exception:
        try:
            os.unlink(tmp_path)
        except FileNotFoundError:
            pass
        raise


def download_with_fallback(urls: List[str], destination: str) -> str:
    errors = []
    for url in urls:
        try:
            download_file(url, destination)
            return url
        except Exception as exc:
            errors.append(f"{url}: {exc}")

    raise RuntimeError("; ".join(errors))


def cmd_query(args: argparse.Namespace) -> int:
    title = " ".join(args.title).strip()
    if not title or len(title) < 2:
        print(json.dumps(alfred_items("Finding papers on DBLP", "Please type at least 2 characters"), ensure_ascii=False))
        return 0

    limit = max(1, min(args.limit, 50))
    payload = query_with_fallback(
        title,
        limit,
        file_path=args.file,
        index_path=args.index,
    )
    items = payload.get("items", [])

    if args.bibtex:
        bibtex_items = [str(item["bibtex"]) for item in items if isinstance(item, dict) and item.get("bibtex")]
        if not bibtex_items:
            if items and isinstance(items[0], dict) and items[0].get("valid") is False:
                title_text = str(items[0].get("title", "DBLP query failed"))
                subtitle_text = str(items[0].get("subtitle", ""))
                print(f"{title_text}: {subtitle_text}".rstrip(": "), file=sys.stderr)
                return 1
            print("No matching title found.", file=sys.stderr)
            return 1
        print("\n\n".join(bibtex_items))
        return 0

    print(json.dumps(payload if args.raw else {"items": items}, ensure_ascii=False))
    return 0


def cmd_pull(args: argparse.Namespace) -> int:
    try:
        return pull_index_from_server()
    except KeyboardInterrupt:
        print("Interrupted while pulling DBLP index.", file=sys.stderr)
        return 1


def cmd_update(args: argparse.Namespace) -> int:
    index_path = args.index or default_index_path(args.output)
    if args.no_download:
        if not os.path.exists(args.output):
            print(f"XML file not found: {args.output}", file=sys.stderr)
            return 2
        used_url = None
    else:
        try:
            used_url = download_with_fallback(DEFAULT_XML_URLS, args.output)
        except Exception as exc:
            print(f"Failed to download update file: {exc}", file=sys.stderr)
            return 1

    try:
        rebuild_index_for_paths(args.output, index_path)
    except Exception as exc:
        if used_url is None:
            print(f"Failed to build index: {exc}", file=sys.stderr)
        else:
            print(f"Updated XML, but failed to build index: {exc}", file=sys.stderr)
        return 1

    size = os.path.getsize(args.output)
    if used_url is None:
        print(f"Using existing {args.output} ({size} bytes)")
    else:
        print(f"Updated {args.output} from {used_url} ({size} bytes)")
    print(f"Built index {index_path} for {args.output}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    default_xml = os.path.join(os.path.dirname(os.path.abspath(__file__)), "dblp.xml.gz")
    parser = argparse.ArgumentParser(prog="dblp")
    parser.add_argument("--raw", action="store_true", help="Print the full response payload")
    subparsers = parser.add_subparsers(dest="command")

    query_parser = subparsers.add_parser("query", help="Query DBLP by title")
    query_parser.add_argument("title", nargs="*", help="Publication title to search for")
    query_parser.add_argument("--limit", type=int, default=10, help="Maximum number of results")
    query_parser.add_argument(
        "--file",
        default=None,
        help="Path used to derive the local SQLite index path (default: DB_PATH/dblp.xml.gz)",
    )
    query_parser.add_argument(
        "--index",
        default=None,
        help="Path to the local SQLite query index (default: <file>.idx.sqlite3)",
    )
    query_parser.add_argument("--raw", action="store_true", help="Print the full response payload")
    query_parser.add_argument("--bibtex", action="store_true", help="Print matching BibTeX entries")
    query_parser.set_defaults(func=cmd_query)

    pull_parser = subparsers.add_parser(
        "pull",
        help="Download the completed SQLite index from the configured DBLP server",
    )
    pull_parser.set_defaults(func=cmd_pull)

    update_parser = subparsers.add_parser(
        "update",
        help="Download the latest dblp.xml.gz and rebuild the local query index",
    )
    update_parser.add_argument(
        "--output",
        default=default_xml,
        help="Path to write dblp.xml.gz (default: %(default)s)",
    )
    update_parser.add_argument(
        "--index",
        default=None,
        help="Path to rebuild the local SQLite query index (default: <output>.idx.sqlite3)",
    )
    update_parser.add_argument(
        "--no-download",
        action="store_true",
        help="Rebuild the local query index from the existing output file",
    )
    update_parser.set_defaults(func=cmd_update)

    return parser


def main(argv: Optional[Iterable[str]] = None) -> int:
    parser = build_parser()
    parsed_argv = list(argv) if argv is not None else sys.argv[1:]
    if parsed_argv and parsed_argv[0] not in {"query", "pull", "update", "--raw", "-h", "--help"}:
        parsed_argv = ["query", *parsed_argv]
    args = parser.parse_args(parsed_argv)
    if args.command is None:
        args = parser.parse_args(["query"])
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
